  X-UA-Compatible: IE=edge
  Cache-Control: public, max-age=3600, must-revalidate
  Link: </assets/images/logo.webp>; rel=preload; as=image, </tailwind-compiled.css>; rel=preload; as=style, </main.js>; rel=preload; as=script
  Vary: Accept-Encoding
  Access-Control-Allow-Origin: *
