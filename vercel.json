{
  "version": 3,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "^/courses/?$", "dest": "/courses.html" },
    { "src": "^/course-quran/?$", "dest": "/course-quran.html" },
    { "src": "^/course-arabic/?$", "dest": "/course-arabic.html" },
    { "src": "^/course-islamic/?$", "dest": "/course-islamic.html" },
    { "src": "^/enroll/?$", "dest": "/enroll.html" },
    { "src": "^/thank-you/?$", "dest": "/thank-you.html" },
    { "src": "^/assets/(.*)$", "dest": "/assets/$1" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ]
}
